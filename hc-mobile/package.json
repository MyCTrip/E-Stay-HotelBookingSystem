{
  "name": "estay-mobile",
  "version": "1.0.0",
  "description": "E-Stay Hotel Booking Mobile Apps (Mini Program + Web H5)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:mini": "pnpm -F @estay/mini-program dev:weapp",
    "dev:web": "pnpm -F @estay/web-h5 dev",
    "build": "pnpm -r build",
    "build:mini": "pnpm -F @estay/mini-program build:weapp",
    "build:web": "pnpm -F @estay/web-h5 build",
    "type-check": "pnpm -r type-check",
    "lint": "eslint packages --ext .ts,.tsx",
    "format": "prettier --write 'packages/**/*.{ts,tsx,json,scss,css}'"
  },
  "devDependencies": {
    "@nutui/icons-react": "^3.0.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
