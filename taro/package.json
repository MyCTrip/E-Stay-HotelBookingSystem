{
  "name": "estay-taro",
  "version": "1.0.0",
  "description": "E-Stay Hotel Booking WeChat Mini Program (Taro)",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "build:h5": "taro build --type h5",
    "dev:h5": "taro build --type h5 --watch",
    "start": "npm run dev:weapp",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@estay/shared": "workspace:*",
    "@tanstack/react-query": "^5.28.0",
    "@tarojs/components": "^3.6.0",
    "@tarojs/react": "^3.6.0",
    "@tarojs/runtime": "^3.6.0",
    "@tarojs/taro": "^3.6.0",
    "react": "^18.2.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@tarojs/cli": "^3.6.0",
    "@tarojs/helper": "^3.6.0",
    "@tarojs/plugin-framework-react": "^3.6.0",
    "@tarojs/plugin-platform-weapp": "^3.6.0",
    "@tarojs/webpack5-runner": "^3.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.37",
    "babel-preset-taro": "^3.6.0",
    "postcss": "^8.4.32",
    "postcss-preset-env": "^11.1.3",
    "typescript": "^5.3.3"
  }
}
