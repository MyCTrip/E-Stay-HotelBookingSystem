{
  "name": "estay-mobile",
  "version": "1.0.0",
  "description": "E-Stay Hotel Booking Mobile Apps (H5 + WeChat Mini Program)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm -F estay-web dev",
    "dev:taro": "pnpm -F estay-taro dev:weapp",
    "build": "pnpm -r build",
    "build:web": "pnpm -F estay-web build",
    "build:taro": "pnpm -F estay-taro build:weapp",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
